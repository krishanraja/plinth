# Plinth environment. Copy to .env and fill in. NEVER commit .env (gitignored).

# --- Client + SSR (public, RLS-gated; safe to expose) ---
SUPABASE_PROJECT_ID="your-project-ref"
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"

# --- Server-only secrets (set in Vercel project env, never in the client bundle) ---
# SUPABASE_SERVICE_ROLE_KEY="..."        # writes to usage_events/resolutions/product_cache; bypasses RLS
# PLINTH_EXTRACTOR_URL="https://..."     # standalone extraction worker (Phase 1)
# PLINTH_EXTRACTOR_TOKEN="..."           # worker auth
# X402_RECIPIENT="0x..."                 # Base Sepolia recipient (Phase 3); NEVER leave at the zero address
# RESEND_API_KEY="..."                   # transactional email (Phase 4)
# STRIPE_SECRET_KEY="..."                # billing (post-beta)
# STRIPE_WEBHOOK_SECRET="..."            # billing webhook signature (post-beta)
